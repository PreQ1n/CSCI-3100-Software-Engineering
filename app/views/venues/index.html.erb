<h1>Venue List - CUHK Venue Booking System</h1>

<div style="margin: 20px 0;">
  <%= form_with(url: venues_path, method: :get, 
                data: {  
                  turbo_frame: "venues_table", 
                  turbo_action: "advance",
                  controller: "search-form" 
                }) do |form| %>
    
    <div style="display: flex; gap: 10px; align-items: center;">
      <%= form.text_field :query,
                         value: params[:query], # Changed from :search to :query
                         placeholder: "Start typing to search...",
                         autocomplete: "off",
                         data: { 
                          action: "input->search-form#search" # Fixed arrow syntax
                         },
                         style: "width: 300px; padding: 8px;" %>
    
      <%= form.button type: :submit, style: "padding: 8px 20px; ..." do %>
        <i class="bi bi-search"></i> Search
      <% end %>      

      <%= link_to "Clear", venues_path, style: "..." %>
    </div>
  <% end %>
</div>

<%# Only render the partial here. Ensure the turbo_frame_tag is INSIDE the partial %>
<%= render "venues_table", venues_table: @venues_table %>

<br>
<%= link_to "Add New Venue", new_venue_path, data: { turbo: false } %>