<section class="surface-card" style="padding: 16px;">
<h1 class="title-ui">Venue List - CUHK Venue Booking System</h1>

<div style="margin: 14px 0;">
  <%= form_with(url: venues_path, method: :get, 
                data: {  
                  turbo_frame: "venues_table", 
                  turbo_action: "advance",
                  controller: "search-form" 
                }) do |form| %>
    
    <div style="display: flex; gap: 10px; align-items: center;">
      <%= form.text_field :query,
                         value: params[:query],
                         placeholder: "Start typing to search...",
                         autocomplete: "off",
                         data: { 
                          action: "input->search-form#search" 
                         },
                         style: "width: 300px; padding: 9px 11px; border: 1px solid #e2e8f0; border-radius: 9px;" %>
    
      <%= form.button type: :submit, class: "btn-ui" do %>
        <i class="bi bi-search"></i> Search
      <% end %>      
      <%= link_to venues_path, class: "btn-ui" do %>
      <i class="bi bi-arrow-counterclockwise"></i> Clear
      <% end %> 
    </div>
  <% end %>
</div>

<%= render "venues_table", venues_table: @venues_table %>

<br>
<%= link_to "Add New Venue", new_venue_path, data: { turbo: false }, class: "btn-ui secondary" %>
</section>
