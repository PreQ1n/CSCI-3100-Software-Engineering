<style>
  table { width: 100%; border-collapse: collapse; margin-top: 20px; }
  th, td { padding: 12px 20px; text-align: left; border-bottom: 1px solid #eee; }
  th { background-color: #f8f9fa; font-weight: bold; }

  /* 搜尋文字高亮樣式 */
  mark {
    background-color: #fff3cd;
    color: #856404;
    padding: 0 2px;
    border-radius: 2px;
    font-weight: bold;
  }
</style>

<h1>Venue List - CUHK Venue Booking System</h1>

<div style="margin: 20px 0;">
  <%= form_with url: venues_path, method: :get, 
                data: { controller: "search", turbo_frame: "venues_table" } do |form| %>
    
    <div style="display: flex; gap: 10px; align-items: center;">
      <%# 下拉選單：切換時觸發搜尋 %>
      <%= form.select :search_column, 
                      [["Venue Name", "name"], ["Building", "building"], ["Description", "description"]], 
                      { selected: params[:search_column] }, 
                      { data: { controller: "slim-select", action: "change->search#submit" } } %>

      <%# 文字輸入框：打字時觸發搜尋 %>
      <%= form.text_field :search,
                         value: params[:search],
                         placeholder: "Start typing to search...",
                         autocomplete: "off",
                         list: "venue_suggestions",
                         data: { action: "input->search#submit" },
                         style: "width: 300px; padding: 8px;" %>

      <%# 搜尋按鈕 (備用) %>
      <%= form.button type: :submit, style: "padding: 8px 20px; display: flex; align-items: center; gap: 8px; cursor: pointer; background-color: #f0f0f0; border: 1px solid #ccc; border-radius: 4px;" do %>
        <i class="bi bi-search"></i> Search
      <% end %>      

      <%# 清除按鈕 %>
      <%= link_to venues_path, style: "margin-left: 10px; color: #666; text-decoration: none; display: flex; align-items: center; gap: 5px;" do %>
        <i class="bi bi-arrow-counterclockwise"></i> Clear
      <% end %>
    </div>
  <% end %>
</div>

<%# 自動補完列表 %>
<datalist id="venue_suggestions">
  <% Venue.order(:name).each do |venue| %>
    <option value="<%= venue.name %>">
  <% end %>
</datalist>

<%# Turbo Frame：只有這個區塊會在搜尋時自動更新 %>
<%= turbo_frame_tag "venues_table" do %>
  <table>
    <thead>
      <tr>
        <th>Venue Name</th>
        <th>Building</th>
        <th>Description</th>
        <th colspan="3">Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @venues.each do |venue| %>
        <tr>
          <td><%= highlight(venue.name, params[:search]) %></td>
          <td><%= highlight(venue.building, params[:search]) %></td>
          <td><%= highlight(venue.description, params[:search]) %></td>
          
          <td><%= link_to "Show", venue, data: { turbo: false } %></td>
          <td><%= link_to "Edit", edit_venue_path(venue), data: { turbo: false } %></td>
          <td><%= link_to "Delete", venue, method: :delete, data: { confirm: "Are you sure?", turbo: false } %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<br>
<%= link_to "Add New Venue", new_venue_path, data: { turbo: false } %>