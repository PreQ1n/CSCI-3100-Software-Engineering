<style>
  table {
    width: 100%;
    border-collapse: collapse; /* Ensures borders look clean */
    margin-top: 20px;
  }

  /* Target both header and data cells */
  th, td {
    padding: 12px 20px; /* 12px top/bottom, 20px left/right */
    text-align: left;
    border-bottom: 1px solid #eee; /* Light line between rows */
  }

  th {
    background-color: #f8f9fa; /* Slight background for headers */
    font-weight: bold;
  }
</style>

<h1>Venue List - CUHK Venue Booking System</h1>

<!-- Search Form with Column Selector + Text Input + Datalist Autocomplete -->
<div style="margin: 20px 0;">
  <%= form_with url: venues_path, method: :get, local: true do |form| %>
    <div style="display: flex; gap: 10px; align-items: center;">

      <%= form.select :search_column,
                      options_for_select([
                        ["Venue Name", "name"],
                        ["Building", "building"],
                        ["Description", "description"]
                      ], params[:search_column] || "name"),
                      {},
                      { 
                        style: "padding: 8px; width: 180px;",
                        data: { controller: "slim-select" }
                      } %>

      <%= form.text_field :search,
                         value: params[:search],
                         placeholder: "Please insert the keywords...",
                         style: "width: 320px; padding: 8px;",
                         list: "venue_suggestions",                    
                         data: { controller: "search-autocomplete" } %>

    <%= form.button type: :submit, style: "padding: 8px 20px; display: flex; align-items: center; gap: 8px; cursor: pointer; background-color: #f0f0f0; border: 1px solid #ccc; border-radius: 4px;" do %>
    <i class="bi bi-search"></i>Search
    <% end %>      

    <%= link_to venues_path, style: "margin-left: 10px; color: #666; text-decoration: none; display: flex; align-items: center; gap: 5px;" do %>
    <i class="bi bi-arrow-counterclockwise"></i>Clear
    <% end %>

    </div>
  <% end %>
</div>

<datalist id="venue_suggestions">
  <% Venue.order(:name).each do |venue| %>
    <option value="<%= venue.name %>">
      <%= [venue.name, venue.building, venue.description].compact.join(" • ") %>
    </option>
  <% end %>
</datalist>

<!-- Original Table -->
<table>
  <thead>
    <tr>
      <th>Venue Name</th>
      <th>Building</th>
      <th>Description</th>
      <th>Action</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @venues.each do |venue| %>
      <tr>
        <td><%= venue.name %></td>
        <td><%= venue.building %></td>
        <td><%= venue.description %></td>
        <td><%= link_to "Show", venue %></td>
        <td><%= link_to "Edit", edit_venue_path(venue) %></td>
        <td><%= link_to "Delete", venue, method: :delete, data: { confirm: "Are you sure you want to delete #{venue.name}?" } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to "Add New Venue", new_venue_path %>