<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-store">
  <script>
    (g=>{var h,a,k,p="The Google Maps JavaScript API",c="google",l="importLibrary",q="__ib__",m=document,b=window;b=b[c]||(b[c]={});var d=b.maps||(b.maps={}),r=new Set,e=new URLSearchParams,u=()=>h||(h=new Promise(async(f,n)=>{await (a=m.createElement("script"));e.set("libraries",[...r]+"");for(k in g)e.set(k.replace(/[A-Z]/g,t=>"_"+t[0].toLowerCase()),g[k]);e.set("callback",c+".maps."+q);a.src=`https://maps.${c}apis.com/maps/api/js?`+e;d[q]=f;a.onerror=()=>h=n(Error(p+" could not load."));a.nonce=m.querySelector("script[nonce]")?.nonce||"";m.head.append(a)}));d[l]?console.warn(p+" only loads once. Ignoring:",g):d[l]=(f,...n)=>r.add(f)&&u().then(()=>d[l](f,...n))})({
      key: "<%= ENV['GOOGLE_MAPS_API_KEY'] %>",
      v: "weekly",
      region: "HK",
      language: "en",
    });
  </script>
<% end %>

<%= form_with(model: venue, data: {turbo: false}) do |form| %>
  <% if venue.errors.any? %>
    <div class="venue-form-errors">
      <h2><%= pluralize(venue.errors.count, "error") %> prohibited this venue from being saved:</h2>

      <ul>
        <% venue.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="venue-form-layout">
    <div class="venue-form-fields">
      <div class="field-row">
        <%= form.label :name %>
        <%= form.text_field :name, id: "search-input", placeholder: "Search for a building..." %>
      </div>

      <div class="field-row">
        <%= form.label :building %>
        <%= form.text_field :building, id: "venue_building" %>
      </div>

      <div class="field-row">
        <%= form.label :latitude %>
        <%= form.number_field :latitude, id:"latitude", step: "any" %>
      </div>

      <div class="field-row">
        <%= form.label :longitude %>
        <%= form.number_field :longitude, id:"longitude", step: "any" %>
      </div>

      <div class="field-row">
        <%= form.label :description %>
        <%= form.textarea :description %>
      </div>

      <div class="field-row">
        <%= form.submit %>
      </div>
    </div>

    <div class="venue-map-panel">
      <div id="map" class="venue-map-canvas"></div>
    </div>
  </div>

  <style>
    .venue-form-layout {
      display: grid;
      grid-template-columns: minmax(320px, 1fr) minmax(340px, 1fr);
      gap: 24px;
      align-items: start;
    }

    .venue-form-fields {
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      background: #ffffff;
      padding: 14px;
    }

    .field-row {
      margin-bottom: 12px;
    }

    .venue-form-fields label {
      display: block;
      margin-bottom: 6px;
      font-weight: 600;
      color: #0f172a;
    }

    .venue-form-fields input,
    .venue-form-fields textarea {
      width: 100%;
      border: 1px solid #cbd5e1;
      border-radius: 10px;
      padding: 8px 10px;
      background: #fff;
    }

    .venue-form-fields textarea {
      min-height: 92px;
      resize: vertical;
    }

    .venue-form-fields input[type="submit"] {
      width: auto;
      border: 1px solid #0f172a;
      background: #0f172a;
      color: #fff;
      font-weight: 600;
      padding: 9px 14px;
      cursor: pointer;
    }

    .venue-map-panel {
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      background: #ffffff;
      padding: 12px;
    }

    .venue-map-canvas {
      width: 100%;
      height: 52vh;
      min-height: 360px;
      border-radius: 10px;
      overflow: hidden;
    }

    .venue-form-errors {
      border: 1px solid #fecaca;
      background: #fef2f2;
      color: #991b1b;
      border-radius: 10px;
      padding: 10px 12px;
      margin-bottom: 12px;
    }

    @media (max-width: 920px) {
      .venue-form-layout {
        grid-template-columns: 1fr;
      }

      .venue-map-canvas {
        height: 44vh;
        min-height: 300px;
      }
    }
  </style>
  
  <script>
    let map;
    let marker;

    const latInput = document.getElementById("latitude");
    const lngInput = document.getElementById("longitude");

    const initialLat = parseFloat(latInput.value);
    const initialLng = parseFloat(lngInput.value);
    let center = (!Number.isNaN(initialLat) && !Number.isNaN(initialLng))
      ? { lat: initialLat, lng: initialLng }
      : { lat: 22.3565, lng: 114.1363 }; // default CUHK area

    function updateLatLngFields(lat, lng) {
      latInput.value = lat.toFixed(6);
      lngInput.value = lng.toFixed(6);
    }

    function setMarker(position) {
      if (marker) {
        marker.setPosition(position);
      } else {
        marker = new google.maps.Marker({ map: map, position: position });
      }
    }
    
    async function initMap() {
      if (map) return;

      const { Map, RenderingType } = await google.maps.importLibrary("maps");
      const { Autocomplete } = await google.maps.importLibrary("places");

      window.map = new Map(document.getElementById("map"), {
        center: center,
        zoom: 15,
        renderingType: RenderingType.VECTOR,
        mapId: "MAP_ID",
      });
      map = window.map;

      // Map click -> auto-fill coordinates.
      map.addListener("click", function(event) {
        const lat = event.latLng.lat();
        const lng = event.latLng.lng();
        const clicked = { lat: lat, lng: lng };

        center = clicked;
        setMarker(clicked);
        updateLatLngFields(lat, lng);
      });
      
      const autoComplete = new Autocomplete(
        document.getElementById("search-input"),
        {
          types: ["establishment"],
          bounds: {
            north: 22.42834,
            south: 22.41179,
            east: 114.21307,
            west: 114.20269,
          },
          strictBounds: true,
          fields: ["name", "geometry"],
        }
      );

      autoComplete.addListener("place_changed", function() {
        const place = autoComplete.getPlace();
        if (!place || !place.geometry || !place.geometry.location) return;

        const selectedPlace = {
          name: place.name,
          location: place.geometry.location
        };
      
        document.getElementById("venue_building").value = selectedPlace.name;
        updateLatLngFields(selectedPlace.location.lat(), selectedPlace.location.lng());
        
        center = selectedPlace.location;
        map.setCenter(center);
        setMarker(center);
      });

      // Show existing marker on edit page when coordinates already exist.
      if (!Number.isNaN(initialLat) && !Number.isNaN(initialLng)) {
        setMarker(center);
      }
    }

    initMap();
  </script>
<% end %>