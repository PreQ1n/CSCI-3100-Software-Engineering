<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Booking" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Booking">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %> 
    <%= yield :head %>
    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>
  </head>

  <body>
    <header class="top-nav surface-card">
      <%= link_to "Main Page", root_path, class: "btn-ui primary" %>

      <% if logged_in? %>
        <div class="dropdown">
          <button class="dropdown-button btn-ui">Account</button>
          <div class="dropdown-content">
            <a href="/confirmation">Confirmation</a>
            <a href="/calendar">Calendar</a>
            <a href="/history">History</a>
          </div>
        </div>

        <span class="welcome-pill">
          Welcome! <%= current_user&.admin? ? "Admin" : "User" %>!
        </span>

        <% if current_user&.admin? %>
          <%= link_to "Analytics Dashboard", analytics_dashboard_path, class: "btn-ui secondary" %>
        <% end %>

        <%= button_to "Logout", logout_path, method: :delete, class: "btn-ui" %>
      <% else %>
        <%= link_to "Login", login_path, class: "btn-ui" %>
      <% end %>
    </header>

    <div class="flash-stack" aria-live="polite" aria-atomic="true">
      <% flash.each do |type, message| %>
        <div class="flash flash-<%= type %>" data-turbo-temporary>
          <%= message %>
        </div>
      <% end %>
    </div>
    
    <main>
      <%= yield %>
    </main>

    <style>
      .top-nav {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        flex-wrap: wrap;
        width: min(1080px, 94vw);
        margin: 14px auto 0;
      }

      .top-nav .dropdown {
        position: relative;
      }

      .top-nav .dropdown-button {
        cursor: pointer;
      }

      .top-nav .dropdown-content {
        display: none;
        position: absolute;
        background: #ffffff;
        min-width: 170px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.15);
        z-index: 999;
        border-radius: 10px;
        overflow: hidden;
      }

      .top-nav .dropdown-content a {
        color: #111827;
        padding: 10px 12px;
        text-decoration: none;
        display: block;
      }

      .top-nav .dropdown-content a:hover {
        background: #f3f4f6;
      }

      .top-nav .welcome-pill {
        color: #0f172a;
        background: #f1f5f9;
        border-radius: 999px;
        padding: 8px 12px;
        border: 1px solid #e2e8f0;
        font-weight: 700;
      }

      .top-nav form {
        margin: 0;
      }

      .flash-stack {
        position: fixed;
        top: 18px;
        right: 18px;
        z-index: 1200;
        display: grid;
        gap: 10px;
        width: min(360px, 90vw);
      }

      .flash {
        border-radius: 10px;
        padding: 10px 12px;
        border: 1px solid #e2e8f0;
        background: #ffffff;
        color: #0f172a;
        box-shadow: 0 8px 20px rgba(2, 6, 23, 0.12);
        opacity: 1;
        transform: translateY(0);
        transition: opacity 320ms ease, transform 320ms ease;
      }

      .flash.fade-out {
        opacity: 0;
        transform: translateY(-6px);
      }

      .flash-notice {
        border-color: #bbf7d0;
        background: #f0fdf4;
      }

      .flash-alert,
      .flash-error {
        border-color: #fecaca;
        background: #fef2f2;
      }
    </style>

    <script>
      document.addEventListener("turbo:load", function () {
        document.querySelectorAll(".flash").forEach(function (el) {
          setTimeout(function () {
            el.classList.add("fade-out");
            setTimeout(function () {
              el.remove();
            }, 320);
          }, 2800);
        });
      });
    </script>
  </body>
</html>