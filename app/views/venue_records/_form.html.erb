<%= form_with(model: venue_record, data: {turbo: false}) do |form| %>
  <% if venue_record.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(venue_record.errors.count, "error") %> prohibited this new booking record from being saved:</h2>

      <ul>
        <% venue_record.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  
  <%= form.hidden_field :venue_id, value: @venue_record.venue.id %>

  <div>
    <%= form.label :date, style: "display: block" %>
    <%= form.date_field :date %>
  </div>

  <div>
    <%= form.label :time, style: "display: block" %>
    <%= form.time_field :time %>
  </div>

  <div>
    <%= form.submit "Book" %>
  </div>
<% end %>
