<%= form_with(model: venue_record, data: {turbo: false}) do |form| %>
  <% if venue_record.errors.any? %>
  <div class="errors">
    <ul>
      <% venue_record.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
  <%= form.hidden_field :venue_id, value: @venue_record.venue.id %>

  <div>
    <%= form.label :date, style: "display: block" %>
    <%= form.date_field :date,
      id: "booking_date",
      min: Date.current.to_s,
      data: { venue_id: @venue_record.venue_id, resource_type: "venue" } %>
  </div>

  <div>
    <%= form.label :time, "Select a Time Slot", style: "display: block; font-weight: bold; margin-bottom: 8px;" %>

    <%# Hidden field stores the selected time on submit %>
    <%= form.hidden_field :time, id: "selected_time_value" %>

    <%
      # Pre-load booked times if date already known (edit form or validation error re-render)
      selected_date = @venue_record.date
      booked_times  = selected_date ? VenueRecord
        .where(venue_id: @venue_record.venue.id, date: selected_date)
        .where.not(id: @venue_record.id)
        .pluck(:time)
        .map { |t| t.strftime("%H:%M") } : []
    %>

    <table class="timeslot-table">
      <thead>
        <tr>
          <th>Hour</th>
        </tr>
      </thead>
      <tbody>
        <% (9..21).each do |hour| %>
          <tr>
            <% [":00"].each do |min| %>
              <% slot       = "#{hour.to_s.rjust(2,'0')}#{min}" %>
              <% is_booked  = booked_times.include?(slot) %>
              <% is_selected = @venue_record.time&.strftime("%H:%M") == slot %>
              <td class="timeslot <%= is_booked ? 'booked' : 'available' %> <%= is_selected ? 'selected' : '' %>"
                  data-time="<%= slot %>"
                  <%= 'data-booked="true"' if is_booked %>>
                <%= is_booked ? "Booked" : slot %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @venue_record.errors[:time].any? %>
      <p style="color: red; margin-top: 4px;"><%= @venue_record.errors[:time].first %></p>
    <% end %>
  </div>

  <div>
    <%= form.submit "Book" %>
  </div>
<% end %>