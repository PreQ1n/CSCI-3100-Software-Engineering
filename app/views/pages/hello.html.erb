<section class="home-hero surface-card">
  <h1>CUHK Booking Hub</h1>
  <p>Fast venue and equipment booking with clear confirmation and history tracking.</p>
</section>

<section class="home-actions surface-card">
  <%= link_to "Venues", venues_path, class: "btn-ui" %>
  <%= link_to "Equipments", equipment_index_path, class: "btn-ui" %>
  <%= link_to "Confirmation", confirmation_path, class: "btn-ui" if logged_in? %>
  <%= link_to "Edit Venue record", venue_records_path, class: "btn-ui" if logged_in? %>

  <% if current_user&.admin? %>
    <%= link_to "Create New Venue", new_venue_path, data: { turbo: false }, class: "btn-ui secondary" %>
    <%= link_to "Create New Equipment", new_equipment_path, data: { turbo: false }, class: "btn-ui secondary" %>
  <% end %>
</section>

<style>
  .home-hero {
    margin: 18px auto 12px;
    max-width: 860px;
    text-align: center;
    padding: 26px 16px;
  }

  .home-hero h1 {
    margin: 0;
    color: #1f2937;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    letter-spacing: 0.02em;
  }

  .home-hero p {
    margin: 10px 0 0;
    color: #374151;
    font-size: 1.03rem;
  }

  .home-actions {
    margin: 16px auto 0;
    max-width: 860px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    padding: 14px;
  }
</style>
