<div class="container mt-5">
  <h1 class="history-title text-center mb-4">Booking History</h1>

  <div class="d-flex justify-content-center gap-3 mb-4">
  <%= form_with url: history_path, method: :get, local: true, class: "d-inline" do |f| %>
    <%= f.hidden_field :type, value: 'venue' %>
    <%= f.submit 'Venue Bookings', class: @record_type == 'venue' ? 'btn btn-primary btn-lg' : 'btn btn-secondary btn-lg' %>
  <% end %>

  <%= form_with url: history_path, method: :get, local: true, class: "d-inline" do |f| %>
    <%= f.hidden_field :type, value: 'equipment' %>
    <%= f.submit 'Equipment Bookings', class: @record_type == 'equipment' ? 'btn btn-primary btn-lg' : 'btn btn-secondary btn-lg' %>
  <% end %>
</div>

  <% if @records.any? %>
    <div class="table-responsive">
      <table class="table table-striped table-bordered table-hover">
        <thead class="table-dark">
          <tr>
            <% if @record_type == 'equipment' %>
              <th>Name</th>
              <th>Date</th>
              <th>Is Absence</th>
              <th>Is Return Late</th>
              <th>Time</th>
            <% else %>
              <th>Name</th>
              <th>Date</th>
              <th>Is Absence</th>
              <th>Time</th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @records.each do |record| %>
            <tr>
              <% if @record_type == 'equipment' %>
                <td><%= record.equipment.name %></td>
                <td><%= record.date.strftime('%B %d, %Y') %></td>  <!-- Formatted date -->
                <td><%= record.is_absence ? 'Yes' : 'No' %></td>
                <td><%= record.is_returnLate ? 'Yes' : 'No' %></td>
                <td><%= record.time.strftime('%I:%M %p') %></td>  <!-- Formatted time -->
              <% else %>
                <td><%= record.venue.name %></td>
                <td><%= record.date.strftime('%B %d, %Y') %></td>
                <td><%= record.is_absence ? 'Yes' : 'No' %></td>
                <td><%= record.time.strftime('%I:%M %p') %></td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="alert alert-info text-center">
      <p>No records found.</p>
    </div>
  <% end %>
</div>