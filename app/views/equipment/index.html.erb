<section class="surface-card" style="padding: 16px;">
<h1 class="title-ui">Equipment List - CUHK Venue Booking System</h1>

<div style="margin: 14px 0;">
<%= form_with(url: equipment_index_path, method: :get, data:{
  controller: "search-form", turbo_frame: "equipments", turbo_action: "advance"}) do |form| %>
  <div style="display: flex; gap: 10px; align-items: center;">

    <%= form.text_field :query, 
                      placeholder: "Start typing to search...",
                      autocomplete: "off",
                      data: { 
                        action: "input -> search-form#search" 
                      },
                      style: "width: 300px; padding: 9px 11px; border: 1px solid #e2e8f0; border-radius: 9px;" %>
    <%= form.button type: :submit, class: "btn-ui" do %>
      <i class="bi bi-search"></i> Search
    <% end %>      
    <%= link_to equipment_index_path, class: "btn-ui" do %>
      <i class="bi bi-arrow-counterclockwise"></i> Clear
    <% end %>   
  </div>
  <% end %> 
</div>

<div class="my-16">
  <%= render "equipments", equipments: @equipments %>
</div>

<%= link_to "Create New Equipment", new_equipment_path, class: "btn-ui secondary" %>
</section>